# /etc/lions-creek-rewards/lions-creek-rewards.env
# Production environment for Lions Creek Rewards behind nginx on Lightsail.
NODE_ENV=production
PORT=3000

# Shopify app credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://rewards.yourdomain.com

# Keep this scope list aligned with shopify.app.toml / shopify.app.prod.toml.
# read_all_orders may require Shopify approval for historical access beyond the standard order window.
SCOPES=read_all_orders,read_customers,read_orders,read_products,write_customers,write_discounts

# Prisma / SQLite production database
DATABASE_URL=file:/var/www/lions-creek-rewards/data/prod.sqlite

# Generate long random values for both secrets. Rotate immediately if leaked.
SESSION_SECRET=
JOB_TOKEN=
